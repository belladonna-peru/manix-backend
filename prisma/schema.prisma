generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String          @id @default(cuid())
  username             String          @unique
  email                String          @unique
  password             String
  avatar               String?
  vibe                 String?
  bio                  String?
  createdAt            DateTime        @default(now())
  lastLocationUpdate   DateTime?
  liveLat              Float?
  liveLng              Float?
  locationMode         String?         @default("approximate")
  zoneName             String?
  isOnline             Boolean         @default(false)
  lastSeen             DateTime?
  socketId             String?
  accountType          String          @default("normal")
  businessPlan         String?
  isVerified           Boolean         @default(false)
  followersCount       Int             @default(0)
  followingCount       Int             @default(0)
  business             Business?
  comments             Comment[]
  conversationsOne     Conversation[]  @relation("ConversationUserOne")
  conversationsTwo     Conversation[]  @relation("ConversationUserTwo")
  following            Follow[]        @relation("UserFollowers")
  followers            Follow[]        @relation("UserFollowing")
  receivedRequests     FriendRequest[] @relation("FriendRequestReceiver")
  sentRequests         FriendRequest[] @relation("FriendRequestSender")
  friendshipsOne       Friendship[]    @relation("FriendshipUserOne")
  friendshipsTwo       Friendship[]    @relation("FriendshipUserTwo")
  locationSharesFriend LocationShare[] @relation("LocationShareFriend")
  locationSharesOwned  LocationShare[] @relation("LocationShareOwner")
  messages             Message[]       @relation("MessageSender")
  moments              Moment[]
  orders               Order[]         @relation("UserOrders")
  reactions            Reaction[]
  reviews              Review[]        @relation("UserReviews")
  streams              Stream[]        @relation("UserStreams")
  events               StreamEvent[]   @relation("UserEvents")
  reels                Reel[]
  wallet               Wallet?
  pushToken String?
}

model Moment {
  id           String     @id @default(cuid())
  content      String
  imageUrl     String?
  location     String?
  createdAt    DateTime   @default(now())
  userId       String
  expiresAt    DateTime?
  lat          Float?
  lng          Float?
  locationMode String?
  comments     Comment[]
  user         User       @relation(fields: [userId], references: [id])
  reactions    Reaction[]
  savedBy      SavedMoment[]
}

model Reaction {
  id        String   @id @default(cuid())
  type      String
  createdAt DateTime @default(now())
  userId    String
  momentId  String
  moment    Moment   @relation(fields: [momentId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, momentId, type])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  userId    String
  momentId  String
  moment    Moment   @relation(fields: [momentId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model FriendRequest {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  senderId   String
  receiverId String
  receiver   User     @relation("FriendRequestReceiver", fields: [receiverId], references: [id])
  sender     User     @relation("FriendRequestSender", fields: [senderId], references: [id])

  @@unique([senderId, receiverId])
}

model Friendship {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userOneId String
  userTwoId String
  userOne   User     @relation("FriendshipUserOne", fields: [userOneId], references: [id])
  userTwo   User     @relation("FriendshipUserTwo", fields: [userTwoId], references: [id])

  @@unique([userOneId, userTwoId])
}

model LocationShare {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  ownerId   String
  friendId  String
  mode      String    @default("exact")
  duration  String
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  friend    User      @relation("LocationShareFriend", fields: [friendId], references: [id])
  owner     User      @relation("LocationShareOwner", fields: [ownerId], references: [id])

  @@unique([ownerId, friendId])
}

model Business {
  id             String      @id @default(cuid())
  createdAt      DateTime    @default(now())
  name           String
  description    String?
  category       String
  logo           String?
  lat            Float?
  lng            Float?
  zoneName       String?
  verified       Boolean     @default(false)
  catalog        Json?
  ownerId        String      @unique
  updatedAt      DateTime    @default(now()) @updatedAt
  businessPlan   String      @default("basic")
  businessType   String?
  closeTime      String?
  coverImage     String?
  instagram      String?
  isOpen         Boolean     @default(false)
  mainGoal       String?
  openTime       String?
  surveyDone     Boolean     @default(false)
  targetAudience String?
  totalOrders    Int         @default(0)
  totalRevenue   Float       @default(0)
  totalViews     Int         @default(0)
  website        String?
  whatsapp       String?
  workDays       String?
  owner          User        @relation(fields: [ownerId], references: [id])
  orders         Order[]
  products       Product[]
  promotions     Promotion[]
  reviews        Review[]
}

model Conversation {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  userOneId String
  userTwoId String
  userOne   User      @relation("ConversationUserOne", fields: [userOneId], references: [id])
  userTwo   User      @relation("ConversationUserTwo", fields: [userTwoId], references: [id])
  messages  Message[]

  @@unique([userOneId, userTwoId])
}

model Message {
  id             String       @id @default(cuid())
  content        String       @default("")
  type           String       @default("text") // "text" | "image" | "location" | "audio"
  mediaUrl       String?      // URL de la foto/audio (type = image | audio)
  duration       Int?         // duración del audio en segundos (type = audio)
  lat            Float?       // ubicación compartida (type = location)
  lng            Float?
  createdAt      DateTime     @default(now())
  readAt         DateTime?
  conversationId String
  senderId       String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowers", fields: [followerId], references: [id])
  following   User     @relation("UserFollowing", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model Product {
  id              String           @id @default(cuid())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  businessId      String
  name            String
  description     String?
  price           Float
  imageUrl        String?
  category        String?
  isActive        Boolean          @default(true)
  stock           Int              @default(0)
  section         String?
  isAvailable     Boolean          @default(true)
  discount        Float?
  discountEndsAt  DateTime?
  preparationTime Int?
  tags            String?
  orderItems      OrderItem[]
  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  variants        ProductVariant[]
}

model ProductVariant {
  id         String  @id @default(cuid())
  productId  String
  type       String
  label      String
  extraPrice Float   @default(0)
  stock      Int     @default(0)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id         String      @id @default(cuid())
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  businessId String
  buyerId    String
  status     String      @default("pending")
  total      Float
  notes      String?
  business   Business    @relation(fields: [businessId], references: [id])
  buyer      User        @relation("UserOrders", fields: [buyerId], references: [id])
  items      OrderItem[]
  review     Review?
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String
  variantId    String?
  quantity     Int
  unitPrice    Float
  subtotal     Float
  variantLabel String?
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product @relation(fields: [productId], references: [id])
}

model Stream {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  endedAt     DateTime?
  userId      String
  title       String
  description String?
  category    String?
  isLive      Boolean   @default(true)
  viewers     Int       @default(0)
  peakViewers Int       @default(0)
  duration    Int       @default(0)
  lat         Float?
  lng         Float?
  zoneName    String?
  user        User      @relation("UserStreams", fields: [userId], references: [id], onDelete: Cascade)
}

model StreamEvent {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userId      String
  title       String
  description String?
  scheduledAt DateTime
  category    String?
  isPublic    Boolean  @default(true)
  maxViewers  Int?
  user        User     @relation("UserEvents", fields: [userId], references: [id], onDelete: Cascade)
}

model Promotion {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  businessId  String
  title       String
  description String?
  type        String
  value       Float     @default(0)
  code        String?
  minOrder    Float?
  isActive    Boolean   @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  usageLimit  Int?
  usageCount  Int       @default(0)
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Review {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now())
  businessId String
  userId     String
  orderId    String    @unique
  rating     Int
  comment    String?
  reply      String?
  repliedAt  DateTime?
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  order      Order     @relation(fields: [orderId], references: [id], onDelete: NoAction)
  user       User      @relation("UserReviews", fields: [userId], references: [id], onDelete: NoAction)
}

model Wallet {
  id           String              @id @default(cuid())
  createdAt    DateTime            @default(now())
  userId       String              @unique
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Float               @default(0)
  coins        Int                 @default(0)
  totalSpent   Float               @default(0)
  totalEarned  Float               @default(0)
  totalDonated Float               @default(0)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  walletId      String
  wallet        Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type          String
  amount        Float    @default(0)
  coins         Int      @default(0)
  description   String?
  status        String   @default("completed")
  referenceId   String?
  referenceType String?
}

model Reel {
  id            String     @id @default(cuid())
  createdAt     DateTime   @default(now())
  userId        String
  videoUrl      String
  thumbnailUrl  String?
  title         String     @default("")
  duration      Int?
  views         Int        @default(0)
  likesCount    Int        @default(0)
  commentsCount Int        @default(0)
  user          User       @relation(fields: [userId], references: [id])
  likes         ReelLike[]
}

model ReelLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  reelId    String
  userId    String
  reel      Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@unique([reelId, userId])
}

model SavedMoment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  momentId  String
  moment    Moment   @relation(fields: [momentId], references: [id], onDelete: Cascade)

  @@unique([userId, momentId])
}
